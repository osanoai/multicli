{
  "name": "@osanoai/multicli",
  "version": "1.5.0",
  "description": "MCP server for multi-CLI AI integration (Gemini + Codex)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "multicli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "echo '⚠️  Remember to test locally first!' && npm run build"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "gemini",
    "codex",
    "claude",
    "cli",
    "coding",
    "agent",
    "llm"
  ],
  "author": "arlogilbert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osanoai/multicli.git"
  },
  "bugs": {
    "url": "https://github.com/osanoai/multicli/issues"
  },
  "homepage": "https://github.com/osanoai/multicli#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "mermaid": "^11.12.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitepress": "^1.6.4",
    "vitepress-plugin-mermaid": "^2.0.17",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "overrides": {
    "vitepress": {
      "vite": "^5.4.21"
    },
    "esbuild": "^0.25.0"
  }
}
