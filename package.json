{
  "name": "@osanoai/multicli",
  "version": "1.5.2",
  "description": "MCP server for Multiple CLI coding agent integration (Claude + Gemini + Codex)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "multicli": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "echo '⚠️  Remember to test locally first!' && npm run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "gemini",
    "codex",
    "claude",
    "cli",
    "coding",
    "agent",
    "llm"
  ],
  "author": "arlogilbert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/osanoai/multicli.git"
  },
  "bugs": {
    "url": "https://github.com/osanoai/multicli/issues"
  },
  "homepage": "https://github.com/osanoai/multicli#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "^25.3.3",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
